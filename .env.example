# LexPlan backend
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://127.0.0.1:5173
JSON_BODY_LIMIT=25mb

# Persistence
MONGODB_URI=mongodb://127.0.0.1:27017/lexplan
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=3000
REDIS_URL=
REDIS_OPTIONAL=true

# OCR
OCR_SERVICE_URL=http://127.0.0.1:8765/ocr
OCR_SERVICE_TIMEOUT_MS=120000
OCR_HEALTH_TIMEOUT_MS=3000

# Bilibili course metadata
BILIBILI_PROVIDER=mock
BILIBILI_VIEW_API_URL=https://api.bilibili.com/x/web-interface/view
BILIBILI_REQUEST_TIMEOUT_MS=10000
BILIBILI_USER_AGENT=LexPlan/0.1

# Optional DeepSeek integration
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CARD_MODEL=deepseek-chat
DEEPSEEK_AGENT_MODEL=deepseek-chat
DEEPSEEK_AGENT_TIMEOUT_MS=45000
LEGAL_STUDY_AGENT_INSIGHT_PROVIDER=deterministic

# Runtime identity and local artifacts
LEGAL_STUDY_USER_ID=lexplan-local-user
LEGAL_STUDY_TOOL_RUNTIME_STORE_PATH=data/runtime/legal-study-tool-runtime.json
LEGAL_STUDY_TOOL_EVENT_STORE_PATH=data/runtime/legal-study-tool-events.json
LEGAL_STUDY_TOOL_SNAPSHOT_ROOT=data/runtime/snapshots
LEGAL_STUDY_TOOL_ARTIFACT_ROOT=data/runtime/artifacts
LEGAL_STUDY_TOOL_OBSERVATION_ROOT=data/runtime/observations
