{
  "name": "@lexplan/backend",
  "version": "0.1.0",
  "private": true,
  "description": "LexPlan app-facing Node backend and Agent runtime integration.",
  "main": "dist/server.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node -r dotenv/config -P tsconfig.json src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@hypha/adapters-local": "file:../../Hypha/packages/adapters-local",
    "@hypha/core": "file:../../Hypha/packages/core",
    "@hypha/domain": "file:../../Hypha/packages/domain",
    "@hypha/harness": "file:../../Hypha/packages/harness",
    "@hypha/mcp": "file:../../Hypha/packages/mcp",
    "@hypha/models": "file:../../Hypha/packages/models",
    "@hypha/tools": "file:../../Hypha/packages/tools",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.2",
    "ioredis": "^5.3.0",
    "mongoose": "^8.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.41",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vitest": "^4.1.9"
  }
}
